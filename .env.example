# Google Maps API Key
REACT_APP_GOOGLE_MAPS_API_KEY=AIzaSyDKQvLYHEywVvYX913V223qVoHTqk_2tJA

# BOG Payment Gateway
REACT_APP_BOG_MERCHANT_ID=your_bog_merchant_id_here
REACT_APP_BOG_SECRET_KEY=your_bog_secret_key_here

# Google Pay (Bank of Georgia "georgiancard" gateway)
# TEST until Google approves your production merchant profile, then PRODUCTION
REACT_APP_GOOGLE_PAY_ENV=TEST
# Google Pay merchant ID (from https://pay.google.com/business/console)
REACT_APP_GOOGLE_PAY_MERCHANT_ID=BCR2DN5TU3P7L4RG
REACT_APP_GOOGLE_PAY_MERCHANT_NAME=funfinder
# Gateway parameters supplied by Bank of Georgia
REACT_APP_GOOGLE_PAY_GATEWAY=georgiancard
REACT_APP_GOOGLE_PAY_GATEWAY_MERCHANT_ID=BCR2DN4TXKPITITV
# Backend endpoint that forwards the Google Pay token to BoG order/create
REACT_APP_GOOGLE_PAY_CONFIG_URL=https://base.funfinder.ge/api/v5/payment/bog/google-pay/config
REACT_APP_GOOGLE_PAY_PROCESS_URL=https://base.funfinder.ge/api/v5/payment/bog/google-pay/initiate

# Google Authentication
REACT_APP_GOOGLE_CLIENT_ID=339531091899-o323fb104jqb2c7k3bagllog69rg8i4n.apps.googleusercontent.com

# Apple Pay (Bank of Georgia external integration)
# Merchant identifier passed to ApplePaySession.
# NOTE: with BoG's external flow you do NOT register your own Apple merchant
# ID — BoG acts as the registered merchant. Use the value BoG returns to you
# after they associate your domain (or this placeholder for local dev).
REACT_APP_APPLE_PAY_MERCHANT_ID=merchant.com.funfinder.ge
REACT_APP_APPLE_PAY_DISPLAY_NAME=Funfinder
# The domain you sent to ecommercemerchants@bog.ge — the cert goes under
# public/.well-known/ and must be reachable on this exact host.
REACT_APP_APPLE_PAY_DOMAIN=funfinder.ge
REACT_APP_APPLE_PAY_COUNTRY=GE
REACT_APP_APPLE_PAY_CURRENCY=GEL
# Backend endpoints — must run on the verified domain over HTTPS.
REACT_APP_APPLE_PAY_VALIDATE_URL=https://base.funfinder.ge/api/v5/payment/apple-pay/validate-merchant
REACT_APP_APPLE_PAY_PROCESS_URL=https://base.funfinder.ge/api/v5/payment/apple-pay/process

